import java.util.Arrays;

public class Main {
    public static void main(String[] args) {
        int[] arr = {10, 5, 20, 8, 20};

        Arrays.sort(arr);

        for (int i = arr.length - 2; i >= 0; i--) {
            if (arr[i] != arr[arr.length - 1]) {
                System.out.println("Second largest: " + arr[i]);
                break;
            }
        }
    }
}
